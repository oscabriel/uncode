{
  "name": "uncode",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@zxing/library": "^0.21.3",
      "dotenv": "^17.2.2",
      "fast-png": "^7.0.1",
      "jpeg-js": "^0.4.4",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "vitest": "^3.2.4",
      "convex": "^1.33.1",
      "better-auth": "1.5.3",
      "@convex-dev/better-auth": "^0.11.3",
      "@types/node": "^24.3.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @uncode/backend dev",
    "dev:setup": "turbo -F @uncode/backend dev:setup",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@uncode/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@uncode/config": "workspace:*",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.9"
}
